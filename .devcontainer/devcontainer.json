// For format details, see https://aka.ms/devcontainer.json. For config options, see the
// README at: https://github.com/devcontainers/templates/tree/main/src/typescript-node
{
  "name": "Node.v24, TS, pnpm.v11.5.2, zsh",
  "build": {
    "dockerfile": "Dockerfile"
  },
  "remoteUser": "node",
  // "features": {
  //   "ghcr.io/joshuanianji/devcontainer-features/mount-pnpm-store:1": {},
  //   "ghcr.io/nils-geistmann/devcontainers-features/zsh:0": {
  //     "defaultUser": true,
  //     "setLocale": true,
  //     "theme": "avit",
  //     "plugins": "git docker",
  //     "desiredLocale": "en_US.UTF-8 UTF-8"
  //   }
  // }

  // Features to add to the dev container. More info: https://containers.dev/features.
  // "features": {},

  // Use 'forwardPorts' to make a list of ports inside the container available locally.
  "forwardPorts": [3000, 4000, 5432, 5050],

  // Use 'postCreateCommand' to run commands after the container is created.
  // "postCreateCommand": "yarn install",

  // Configure tool-specific properties.
  "customizations": {
    "vscode": {
      "settings": {
        // Force VS Code to use Zsh as the default terminal
        "terminal.integrated.defaultProfile.linux": "zsh",
        "terminal.integrated.profiles.linux": {
          "zsh": {
            "path": "/bin/zsh",
            "args": ["-l"] 
          }
        },
        "editor.formatOnSave": true
      }
    }
  }

  // Uncomment to connect as root instead. More info: https://aka.ms/dev-containers-non-root.
  // "remoteUser": "root"
}
